# Paths
DB_PATH=outputs/sales_ops.db
REPORT_PATH=outputs/daily_ops_report.xlsx
POWERBI_CSV_PATH=outputs/powerbi_dataset.csv
RAW_DATA_DIR=data
PROCESSED_DATA_DIR=outputs/processed

# Slack alerting
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#sales-ops
SLACK_ENABLED=false

# Business rules
STALLED_DAYS=7
AT_RISK_DAYS=5
AT_RISK_CLOSE_WINDOW_DAYS=7

# Scheduling
SCHEDULE_TIME=08:00

# Demo date shift
# Set to a date like 2026-06-15 to simulate "today" for the public dataset.
# If empty, the pipeline uses the actual current date.
SIMULATED_TODAY=
